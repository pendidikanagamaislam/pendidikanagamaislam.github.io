---

---

<div id="welcome-screen" class="welcome-screen">

  <div class="noise"></div>
  <div class="grid-overlay"></div>
  <div class="background-glow"></div>

  <div class="welcome-box">

    <div class="security-badge">
      SECURITY ACTIVE
    </div>

    <h1 class="main-title">
      SELAMAT DATANG
    </h1>

    <p class="subtitle">
      WEBSITE INI DILINDUNGI OLEH PROFESSIONAL CYBER SECURITY
    </p>

    <div class="divider"></div>

    <p class="enter-text">
      ANDA AKAN MEMASUKI WEBSITE DALAM WAKTU
      <span id="countdown-text">10</span>
      DETIK
    </p>

    <div class="countdown">
      <span id="countdown-number">10</span>
    </div>

  </div>

</div>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const screen = document.getElementById("welcome-screen");

    // tampil sekali
    if (sessionStorage.getItem("welcomeShown")) {
      return;
    }

    screen.style.display = "flex";

    sessionStorage.setItem("welcomeShown", "true");

    const countdown = document.getElementById("countdown-number");
    const countdownText = document.getElementById("countdown-text");

    let timeLeft = 10;

    const timer = setInterval(() => {
      timeLeft--;

      if (countdown && timeLeft >= 0) {
        countdown.textContent = timeLeft;
      }

      if (countdownText && timeLeft >= 0) {
        countdownText.textContent = timeLeft;
      }

      if (timeLeft <= 0) {
        clearInterval(timer);

        setTimeout(() => {
          screen.classList.add("hide");

          setTimeout(() => {
            screen.remove();
          }, 900);
        }, 400);
      }
    }, 1000);
  });
</script>

<style>
  .welcome-screen {
    display: none;

    position: fixed;
    inset: 0;
    z-index: 999999;

    align-items: center;
    justify-content: center;

    overflow: hidden;

    padding: 1.5rem;

    background:
      radial-gradient(circle at top, #071018 0%, #010409 45%, #000000 100%);

    transition:
      opacity 0.9s ease,
      visibility 0.9s ease;
  }

  .noise {
    position: absolute;
    inset: 0;

    opacity: 0.05;

    background-image:
      url("https://www.transparenttextures.com/patterns/asfalt-dark.png");

    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;

    background-image:
      linear-gradient(rgba(0,255,170,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,170,0.05) 1px, transparent 1px);

    background-size: 45px 45px;

    mask-image: radial-gradient(circle at center, black 35%, transparent 100%);
  }

  .background-glow {
    position: absolute;

    width: 650px;
    height: 650px;

    border-radius: 999px;

    background:
      radial-gradient(circle, rgba(0,255,170,0.15), transparent 70%);

    filter: blur(120px);

    animation: pulseGlow 5s ease-in-out infinite;
  }

  .welcome-box {
    position: relative;
    z-index: 2;

    width: 100%;
    max-width: 900px;

    padding: 0;

    text-align: center;

    background: transparent;
    border: none;
    border-radius: 0;
    backdrop-filter: none;
    box-shadow: none;
  }

  .security-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 0.7rem 1.4rem;

    margin-bottom: 2rem;

    border:
      1px solid rgba(0,255,170,0.2);

    border-radius: 999px;

    background:
      rgba(0,255,170,0.06);

    color: #67ffd2;

    font-size: 0.78rem;
    font-weight: 800;

    letter-spacing: 3px;

    text-transform: uppercase;

    box-shadow:
      0 0 20px rgba(0,255,170,0.08);
  }

  .main-title {
    color: #f8fafc;

    font-size: clamp(3rem, 8vw, 5.8rem);

    font-weight: 900;

    line-height: 1;

    letter-spacing: 8px;

    margin-bottom: 2rem;

    text-transform: uppercase;

    text-shadow:
      0 0 10px rgba(255,255,255,0.15),
      0 0 30px rgba(0,255,170,0.12),
      0 0 80px rgba(0,255,170,0.08);

    animation:
      titleFloat 4s ease-in-out infinite;
  }

  .subtitle {
    max-width: 650px;

    margin: 0 auto;

    padding-inline: 1rem;

    color: #d1fae5;

    font-size: clamp(1rem, 2vw, 1.18rem);

    font-weight: 700;

    line-height: 2;

    letter-spacing: 3px;

    text-transform: uppercase;

    text-shadow:
      0 0 12px rgba(0,255,170,0.25),
      0 0 24px rgba(0,255,170,0.12);
  }

  .divider {
    width: 160px;
    height: 1px;

    margin: 2.5rem auto;

    background:
      linear-gradient(
        to right,
        transparent,
        rgba(0,255,170,0.8),
        transparent
      );

    box-shadow:
      0 0 12px rgba(0,255,170,0.4);
  }

  .enter-text {
    color: #94a3b8;

    font-size: 0.95rem;

    line-height: 1.9;

    letter-spacing: 2px;

    text-transform: uppercase;

    margin-bottom: 2rem;
  }

  .enter-text span {
    color: #00ffaa;

    font-weight: 800;

    text-shadow:
      0 0 10px rgba(0,255,170,0.5);
  }

  .countdown {
    width: 120px;
    height: 120px;

    margin: 0 auto;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 26px;

    border:
      1px solid rgba(0,255,170,0.25);

    background:
      linear-gradient(
        180deg,
        rgba(255,255,255,0.04),
        rgba(0,255,170,0.02)
      );

    backdrop-filter: blur(10px);

    box-shadow:
      inset 0 0 25px rgba(0,255,170,0.06),
      0 0 30px rgba(0,255,170,0.08);
  }

  .countdown span {
    color: #ffffff;

    font-size: 3.2rem;

    font-weight: 900;

    line-height: 1;

    text-shadow:
      0 0 18px rgba(0,255,170,0.4);
  }

  .hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transform: scale(1.03);
  }

  @keyframes pulseGlow {
    0%, 100% {
      transform: scale(1);
      opacity: 0.8;
    }

    50% {
      transform: scale(1.08);
      opacity: 1;
    }
  }

  @keyframes titleFloat {
    0%, 100% {
      transform: translateY(0px);
    }

    50% {
      transform: translateY(-5px);
    }
  }

  @media (max-width: 640px) {
    .welcome-box {
      padding: 3rem 1.3rem;
    }

    .subtitle {
      line-height: 1.8;
      letter-spacing: 1.5px;
    }

    .enter-text {
      font-size: 0.78rem;
      line-height: 1.8;
    }

    .countdown {
      width: 90px;
      height: 90px;

      border-radius: 20px;
    }

    .countdown span {
      font-size: 2.3rem;
    }
  }
</style>