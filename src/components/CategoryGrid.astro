---
import { CATEGORIES } from '../data/site';
---
<section class="py-16" aria-labelledby="kategori-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 id="kategori-heading" class="text-3xl font-bold text-gray-900 dark:text-white mb-3">
        Jelajahi Kategori
      </h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-xl mx-auto">
        Temukan artikel sesuai topik yang ingin Anda pelajari.
      </p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {CATEGORIES.map(cat => (
        <a
          href={`/kategori/${cat.slug}`}
          class="group flex flex-col items-center gap-3 p-5 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover text-center"
        >
          <span class="text-3xl group-hover:scale-110 transition-transform duration-300" aria-hidden="true">
            {cat.icon}
          </span>
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-200 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-200">
            {cat.label}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
