---
import { formatDate, readingTime, categoryColor } from '../utils/helpers';

export interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  author: string;
  image?: string;
  featured?: boolean;
  body?: string;
}

const { title, description, slug, pubDate, category, author, image, featured = false, body = '' } = Astro.props;
const rt = body ? readingTime(body) : '';
const badge = categoryColor(category);
---
<article class={`group bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 card-hover ${featured ? 'ring-2 ring-primary-300 dark:ring-primary-700' : ''}`}>
  <!-- Image -->
  {image ? (
    <a href={`/blog/${slug}`} class="block overflow-hidden" tabindex="-1" aria-hidden="true">
      <img
        src={image}
        alt={title}
        class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width="400" height="192"
      />
    </a>
  ) : (
    <a href={`/blog/${slug}`} class="block overflow-hidden" tabindex="-1" aria-hidden="true">
      <div class="w-full h-48 gradient-ocean opacity-80 flex items-center justify-center">
        <svg class="w-14 h-14 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
    </a>
  )}

  <!-- Content -->
  <div class="p-5">
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      {featured && (
        <span class="badge bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">
          ⭐ Unggulan
        </span>
      )}
      <span class={`badge ${badge}`}>{category}</span>
      {rt && <span class="text-xs text-gray-500 dark:text-gray-400">{rt}</span>}
    </div>

    <h3 class="font-bold text-gray-900 dark:text-white mb-2 leading-snug group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors duration-200">
      <a href={`/blog/${slug}`} class="block">
        {title}
      </a>
    </h3>

    <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4 leading-relaxed">
      {description}
    </p>

    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 gradient-ocean rounded-full flex items-center justify-center text-white text-xs font-bold">
          {author.charAt(0).toUpperCase()}
        </div>
        <span class="text-xs text-gray-500 dark:text-gray-400">{author}</span>
      </div>
      <time datetime={pubDate.toISOString()} class="text-xs text-gray-400 dark:text-gray-500">
        {formatDate(pubDate)}
      </time>
    </div>
  </div>
</article>
