---
import { NAV_LINKS, SITE } from '../data/site';
const currentPath = Astro.url.pathname;
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Beranda">
        <div class="w-9 h-9 gradient-ocean rounded-xl flex items-center justify-center shadow-md group-hover:shadow-primary-500/40 transition-shadow duration-300">
          <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-white" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="currentColor" opacity="0.3"/>
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" fill="currentColor"/>
            <path d="M7 10.5C7 8.57 8.57 7 10.5 7S14 8.57 14 10.5c0 .73-.21 1.41-.57 1.98L16 15h-1.5l-2.27-2.27c-.22.04-.45.07-.68.07A3.502 3.502 0 017 10.5zm3.5-2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="currentColor"/>
          </svg>
        </div>
        <span class="text-lg font-bold text-gray-900 dark:text-white">{SITE.title}</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {NAV_LINKS.map(link => (
          <li>
            <a
              href={link.href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'bg-primary-100 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300'
                  : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'
              }`}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right actions -->
      <div class="flex items-center gap-2">
        <!-- Search -->
        <a href="/blog#search" aria-label="Cari artikel"
           class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </a>

        <!-- Dark mode toggle -->
        <button id="theme-toggle" aria-label="Ganti tema" type="button"
                class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">
          <!-- Sun (show in dark mode) -->
          <svg id="icon-sun" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <!-- Moon (show in light mode) -->
          <svg id="icon-moon" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button id="menu-btn" type="button" aria-label="Buka menu" aria-expanded="false" aria-controls="mobile-menu"
                class="md:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200">
          <span id="icon-open" class="block">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </span>
          <span id="icon-close" class="hidden">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden" role="dialog" aria-label="Menu navigasi">
    <div class="navbar-glass border-t border-gray-200/50 dark:border-gray-700/50 px-4 py-3 space-y-1">
      {NAV_LINKS.map(link => (
        <a
          href={link.href}
          class={`block px-4 py-2.5 rounded-xl text-sm font-medium transition-colors duration-200 ${
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'bg-primary-100 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300'
              : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Dark mode toggle
  const themeBtn = document.getElementById('theme-toggle')!;
  themeBtn.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Hamburger
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar')!;
  const updateNavbar = () => {
    if (window.scrollY > 20) {
      navbar.classList.add('navbar-glass', 'shadow-sm');
    } else {
      navbar.classList.remove('navbar-glass', 'shadow-sm');
    }
  };
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();
</script>
