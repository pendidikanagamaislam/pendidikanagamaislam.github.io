---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../data/site';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const cats = [...new Set(allPosts.map(p => p.data.category.toLowerCase()))];
  return cats.map(kategori => ({
    params: { kategori },
    props: {
      posts: allPosts
        .filter(p => p.data.category.toLowerCase() === kategori)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { kategori } = Astro.params;
const { posts } = Astro.props;
const catInfo = CATEGORIES.find(c => c.slug === kategori);
const label = catInfo?.label ?? kategori;
const icon = catInfo?.icon ?? '📚';
---
<BaseLayout
  title={`Kategori: ${label}`}
  description={`Artikel PAI kategori ${label} — ${posts.length} artikel tersedia.`}
>
  <div class="pt-24 pb-8 gradient-ocean">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-4xl mb-3" aria-hidden="true">{icon}</div>
      <h1 class="text-4xl font-bold text-white mb-2">{label}</h1>
      <p class="text-primary-100">{posts.length} artikel ditemukan</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Kategori', href: '/kategori' }, { label: label }]} />

    {posts.length > 0 ? (
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            category={post.data.category}
            author={post.data.author}
            image={post.data.image}
            body={post.body}
          />
        ))}
      </div>
    ) : (
      <div class="mt-12 text-center py-16">
        <div class="text-6xl mb-4" aria-hidden="true">📭</div>
        <p class="text-gray-500 dark:text-gray-400">Belum ada artikel di kategori ini.</p>
        <a href="/blog" class="mt-4 btn-primary inline-flex">Lihat semua artikel</a>
      </div>
    )}
  </div>
</BaseLayout>
