---
import BaseLayout from "../../layouts/BaseLayout.astro";

const quizzes = [
  {
    title: "Quiz Rukun Islam",
    description: "Uji pemahaman tentang 5 rukun Islam",
    url: "/quiz/rukun-islam"
  },
  {
    title: "Quiz Nabi dan Rasul",
    description: "Belajar kisah nabi dengan quiz seru",
    url: "/quiz/nabi-rasul"
  },
  {
    title: "Quiz Surat Pendek",
    description: "Latihan hafalan surat pendek",
    url: "/quiz/surat-pendek"
  }
];
---

<BaseLayout
  title="Quiz Pendidikan Agama Islam"
  description="Quiz interaktif Pendidikan Agama Islam untuk siswa"
>

<section class="relative overflow-hidden py-20">

  <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-primary-700 to-primary-900"></div>

  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-0 left-0 w-72 h-72 bg-yellow-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-72 h-72 bg-blue-300 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">

    <div class="text-center mb-14">

      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-white text-sm font-semibold backdrop-blur-sm mb-6">
        🧠 Quiz Interaktif PAI
      </div>

      <h1 class="text-4xl md:text-6xl font-black text-white leading-tight mb-6">
        Quiz Pendidikan
        <span class="block text-yellow-300">
          Agama Islam
        </span>
      </h1>

      <p class="max-w-2xl mx-auto text-lg text-primary-100 leading-relaxed">
        Belajar PAI jadi lebih menyenangkan dengan quiz interaktif,
        latihan soal, dan evaluasi pemahaman materi.
      </p>

    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

      {quizzes.map((quiz) => (
        <a
          href={quiz.url}
          class="group relative bg-white/10 backdrop-blur-md border border-white/20 rounded-3xl p-7 hover:bg-white/15 hover:border-yellow-300/50 hover:-translate-y-2 transition-all duration-300 shadow-xl"
        >

          <div class="absolute top-0 right-0 w-24 h-24 bg-yellow-300/10 rounded-full blur-2xl"></div>

          <div class="relative">

            <div class="w-14 h-14 rounded-2xl bg-yellow-300 text-slate-900 flex items-center justify-center text-2xl mb-5 shadow-lg">
              📚
            </div>

            <h2 class="text-2xl font-black text-white mb-3 group-hover:text-yellow-300 transition-colors">
              {quiz.title}
            </h2>

            <p class="text-primary-100 leading-relaxed">
              {quiz.description}
            </p>

            <div class="mt-6 inline-flex items-center gap-2 text-yellow-300 font-bold">
              Mulai Quiz
              <span class="group-hover:translate-x-1 transition-transform">
                →
              </span>
            </div>

          </div>

        </a>
      ))}

    </div>

  </div>

</section>

</BaseLayout>